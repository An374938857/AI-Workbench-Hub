# 数据库
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/ai_platform?charset=utf8mb4

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# 加密（API Key 加密用，使用 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成）
ENCRYPTION_KEY=your-fernet-key-here

# 文件存储
# 生产建议使用仓库外持久目录，例如：/data/ai-skill-sharing-platform/uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# 应用
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
REDIS_URL=redis://localhost:6379/0
CONVERSATION_EVENTS_HEARTBEAT_SEC=15

# 搜索和推荐
ELASTICSEARCH_URL=http://localhost:9200
CHROMA_URL=http://localhost:8000
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# 搜索配置
SEARCH_CACHE_TTL=300
SEARCH_MAX_RESULTS=20

# 推荐配置
RECOMMEND_CACHE_TTL=300
RECOMMEND_TOP_K=3
RECOMMEND_USAGE_WEIGHT=0.4
RECOMMEND_SIMILARITY_WEIGHT=0.6

# 开源版发布种子：Aliyun Coding Plan API Key（可选）
# 设置后首次 bootstrap 会自动注入该提供商，用户可开箱即用
RELEASE_ALIYUN_CODING_PLAN_API_KEY=

# 压缩配置
COMPRESSION_THRESHOLD=30
COMPRESSION_KEEP_RECENT=20
