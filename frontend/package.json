    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.5",
    "beautiful-mermaid": "^1.1.3",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.2",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.12.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
