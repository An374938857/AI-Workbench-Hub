# Docker image mirror prefix for compose `image:` and Dockerfile `FROM`.
# China mainland default:
DOCKER_REGISTRY_MIRROR=docker.m.daocloud.io
# Official source fallback:
# DOCKER_REGISTRY_MIRROR=docker.io

# APT mirror for backend image build.
APT_MIRROR=mirrors.aliyun.com

# PyPI mirror for backend image build.
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple
PIP_TRUSTED_HOST=mirrors.aliyun.com

# NPM registry for frontend image build/runtime install.
NPM_REGISTRY=https://registry.npmmirror.com
